<?xml version="1.0" encoding="utf-8"?>
<!-- Professional launch background with gradient and app icon -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0A2540"
                android:centerColor="#1a3a5a"
                android:endColor="#0A2540"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- App icon in center -->
    <item
        android:gravity="center"
        android:drawable="@mipmap/launcher_icon" />
        
    <!-- Subtle pattern overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#00000000"
                android:endColor="#20000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>